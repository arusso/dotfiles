#!/bin/sh

CLEANUP_BASE_BRANCH="$(git config --get cleanup.base)"
DEFAULT_BRANCH="$(git config --get init.defaultBranch)"

# Fall back to default branch, then master as last resort
BASE_BRANCH=${CLEANUP_BASE_BRANCH:-${DEFAULT_BRANCH:-master}}

function usage() {
  printf "usage: $(basename $0) [noop|usage]\n\n"
  printf "Finds local branches that have already been merged into the main branch, usually\n"
  printf "master, and offers to delete both the local and remote copy for you.\n"
  printf "\n"
  printf "If a branch other than master exists, you can set cleanup.base setting equal to\n"
  printf "the name of your master branch.\n"
}

function get_branches_to_clean() {
  local curr=$(git branch | sed -n 's/^\*\ *//p')
  local base=${BASE_BRANCH}

  [[ "$curr" == "${base}" ]] || git checkout "$base" &>/dev/null
  if [ $? -eq 0 ]; then
    local to_clean="$(git branch --merged "$base" | sed 's/^[* ]*//' | grep -v "^${base}$" | grep -v "^${curr}$")"
    [[ "$curr" == "${base}" ]] || git checkout "$curr" &>/dev/null
    local branch=""
    for branch in $to_clean; do
      is_branch_ignored "$branch"
      [[ $? -eq 0 ]] && echo "$branch"
    done
  else
    echo "unable to switch to branch '${base}'"
    echo ""
    echo "This usually happens when your base branch is something other than 'master'."
    echo "If this describes your situation, try running the following command replacing"
    echo "\$BRANCH with the base branch for your repository"
    echo ""
    echo "   $ git config cleanup.base \$BRANCH"
    exit 1
  fi
}

function is_branch_ignored() {
  local branch=$1
  local ignore=$(git config --get cleanup.ignore)
  for b in $ignore; do
    [[ "$branch" == "$b" ]] && return 1
  done
  return 0
}

if  [ $# -gt 1 ]; then
  usage
  exit 1
fi

opt=$(echo $1 | tr '[:upper:]' '[:lower:]')

if [ "$opt" = "usage" ] || [ "$opt" = "u" ]; then
  usage
  exit 0
elif [ "$opt" == "noop" ] || [ "$opt" == "n" ]; then
  get_branches_to_clean
  exit
else
  to_clean=$(get_branches_to_clean)
  [ -z "$to_clean" ] && exit
  printf "please confirm you want to clean (remove) the following local branches:\n\n  Branches:\n\n"
  for br in $to_clean; do
    printf "  %s\n" "$br"
  done
  printf "\n> (y|N): "
  read -r ans
  ans=$(echo "$ans" | tr '[:upper:]' '[:lower:]')
  if [ "$ans" = "yes" ] || [ "$ans" = "y" ]; then
    for br in $to_clean; do
      git branch -d "$br" 2>&1 1>/dev/null && git push origin --delete "$br" 2>&1 1>/dev/null
    done
  fi
fi
